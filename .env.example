# ── Supabase (LEADS-prosjektet, krawpaxz) ─────────────────────────────
SUPABASE_URL=https://krawpaxzwygnvoueykcc.supabase.co
# Hent service_role-nøkkelen her: Supabase → Project Settings → API → "service_role" (secret).
# NB: service_role har full tilgang. Den skal KUN ligge her lokalt / på server — aldri i frontend eller GitHub.
SUPABASE_SERVICE_KEY=DIN_SERVICE_ROLE_NOKKEL

# ── Google Places (legacy API) ────────────────────────────────────────
# Krever aktiv billing på Google Cloud-prosjektet (clean-pottery-495512-a8 eller det du bruker nå).
GOOGLE_PLACES_API_KEY=DIN_GOOGLE_PLACES_NOKKEL

# ── Valgfritt ─────────────────────────────────────────────────────────
PORT=3000
# Apps Script-lenka arket ligger bak (brukes bare av importer.js). Endre den her hvis du har en ny.
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwWQn_iHX-6h716fdhdFWC5dilH_enNWbB_6XnHyWFcwaSX_BJOZ570TJvh2GbM4AVomA/exec
